---
// Architecture diagram — CSS layout (responsive, no SVG fragility)
---

<section class="arch" id="how-it-works">
  <div class="arch-inner">
    <div class="section-eyebrow">ARCHITECTURE</div>
    <h2>Control plane you deploy,<br>providers you trust</h2>
    <p class="arch-desc">
      A lightweight daemon handles all elevation logic. Humans approve via Slack.
      AI agents request via MCP. Everything expires automatically.
    </p>

    <div class="diagram-container">
      <div class="diagram">
        <!-- Requestors -->
        <div class="col">
          <div class="col-header">REQUESTORS</div>
          <div class="col-boxes">
            <div class="box box-cli">CLI (jitsudo)</div>
            <div class="box box-mcp">MCP server</div>
            <div class="box box-slack">Slack bot</div>
          </div>
        </div>

        <!-- Arrow left -->
        <div class="arrow-col">
          <div class="arrow-label">OIDC / gRPC</div>
          <div class="arrow-line">
            <div class="arrow-shaft"></div>
            <div class="arrow-head">›</div>
          </div>
        </div>

        <!-- Control plane -->
        <div class="col col-center">
          <div class="col-header">CONTROL PLANE</div>
          <div class="box box-main">
            <span class="main-name">jitsudod</span>
            <div class="main-badges">
              <span class="inner-badge">OPA</span>
              <span class="inner-badge">PostgreSQL</span>
            </div>
          </div>
        </div>

        <!-- Arrow right -->
        <div class="arrow-col">
          <div class="arrow-label">provider plugin</div>
          <div class="arrow-line">
            <div class="arrow-shaft"></div>
            <div class="arrow-head">›</div>
          </div>
        </div>

        <!-- Providers -->
        <div class="col">
          <div class="col-header">PROVIDERS</div>
          <div class="col-boxes">
            <div class="box">AWS IAM</div>
            <div class="box">Azure AD</div>
            <div class="box">GCP IAM</div>
            <div class="box">Kubernetes RBAC</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .arch {
    padding: 5rem 2rem;
    border-bottom: 1px solid #2a2d31;
  }

  .arch-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .section-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #f97316;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #f8fafc;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .arch-desc {
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 3.5rem;
  }

  .diagram-container {
    background: #1c1e22;
    border: 1px solid #2a2d31;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    overflow-x: auto;
  }

  .diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    min-width: 680px;
  }

  .col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    max-width: 180px;
  }

  .col-center {
    max-width: 200px;
  }

  .col-header {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #64748b;
    text-transform: uppercase;
  }

  .col-boxes {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .box {
    padding: 0.5rem 0.75rem;
    border: 1px solid #2a2d31;
    border-radius: 6px;
    font-size: 0.8rem;
    color: #cbd5e1;
    text-align: center;
    background: #18191b;
  }

  .box-cli {
    border-color: #3a3d42;
    color: #e2e8f0;
  }

  .box-mcp {
    border-color: #1e3a5f;
    background: #0f1e33;
    color: #7dd3fc;
  }

  .box-slack {
    border-color: #3d2a0f;
    background: #1e1507;
    color: #fb923c;
  }

  .box-main {
    padding: 1rem 1.25rem;
    border: 1.5px solid #f97316;
    border-radius: 8px;
    background: #1c1e22;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
  }

  .main-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #f97316;
  }

  .main-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .inner-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid #2a2d31;
    border-radius: 4px;
    color: #94a3b8;
    background: #18191b;
  }

  .arrow-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    padding: 0 0.5rem;
    margin-top: 1.5rem;
  }

  .arrow-label {
    font-size: 0.65rem;
    color: #475569;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .arrow-line {
    display: flex;
    align-items: center;
    gap: 0;
    width: 70px;
  }

  .arrow-shaft {
    flex: 1;
    height: 1px;
    background: #2a2d31;
  }

  .arrow-head {
    color: #475569;
    font-size: 1.1rem;
    line-height: 1;
    margin-left: -2px;
  }

  @media (max-width: 640px) {
    h2 {
      font-size: 1.75rem;
    }
  }
</style>
