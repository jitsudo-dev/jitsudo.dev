---
import Terminal from './Terminal.astro';
---

<section class="hero">
  <div class="hero-inner">
    <!-- Left: copy -->
    <div class="hero-text">
      <div class="badge">
        <span class="badge-dot" aria-hidden="true"></span>
        Apache 2.0 open source
      </div>

      <h1>
        Zero persistent<br>
        admin access.<br>
        Just in time.
      </h1>

      <p class="hero-sub">
        JIT privileged access for AWS, Azure, GCP, and Kubernetes.
        Built for SREs — and the AI agents that work alongside them.
      </p>

      <div class="hero-ctas">
        <a href="/docs/quickstart/" class="btn-primary">Quick start →</a>
        <a href="https://github.com/jitsudo-dev/jitsudo" class="btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>

      <div class="stats" aria-label="key metrics">
        <div class="stat">
          <span class="stat-value">Short-lived</span>
          <span class="stat-label">configurable TTL</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">4</span>
          <span class="stat-label">cloud providers</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">0</span>
          <span class="stat-label">persistent elevation</span>
        </div>
      </div>
    </div>

    <!-- Right: terminal demo -->
    <div class="hero-visual" aria-hidden="true">
      <Terminal />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 2rem 4rem;
    border-bottom: 1px solid #2a2d31;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.85rem;
    border: 1px solid #2a2d31;
    border-radius: 9999px;
    font-size: 0.78rem;
    color: #94a3b8;
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f97316;
    flex-shrink: 0;
  }

  h1 {
    font-size: 3.25rem;
    font-weight: 700;
    line-height: 1.08;
    color: #f8fafc;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: #94a3b8;
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 460px;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    padding: 0.6rem 1.25rem;
    border: 1px solid #f8fafc;
    border-radius: 6px;
    color: #f8fafc;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .btn-primary:hover {
    background: #f8fafc;
    color: #18191b;
  }

  .btn-secondary {
    padding: 0.6rem 1.25rem;
    border: 1px solid #2a2d31;
    border-radius: 6px;
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 450;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .btn-secondary:hover {
    border-color: #4a5568;
    color: #f8fafc;
  }

  .stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #f97316;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: #2a2d31;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 2.5rem;
    }

    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 3rem 1.25rem 2.5rem;
    }

    h1 {
      font-size: 2rem;
    }

    .stats {
      gap: 1rem;
    }
  }
</style>
